# MikoPBX ModuleUsersUI Integration Tests Configuration
# Copy this file to .env and update values for your environment

# =============================================================================
# API Configuration
# =============================================================================

# MikoPBX REST API URL
MIKOPBX_API_URL=http://localhost:8189/pbxcore/api/v3

# Admin credentials for initial authentication
MIKOPBX_API_USERNAME=admin
MIKOPBX_API_PASSWORD=admin

# =============================================================================
# Execution Mode (optional - auto-detected if not set)
# =============================================================================

# Force execution mode: docker|api|ssh|local
# MIKOPBX_EXECUTION_MODE=docker

# Docker container name (for docker mode)
MIKOPBX_CONTAINER=mikopbx_modules-api-refactoring

# SSH configuration (for ssh mode)
# MIKOPBX_SSH_HOST=192.168.1.100
# MIKOPBX_SSH_USER=root
# MIKOPBX_SSH_PORT=22

# =============================================================================
# Database Paths (inside container)
# =============================================================================

# CDR database path
MIKOPBX_CDR_DB_PATH=/storage/usbdisk1/mikopbx/astlogs/asterisk/cdr.db

# ModuleUsersUI database path
MIKOPBX_MODULE_DB_PATH=/storage/usbdisk1/mikopbx/custom_modules/ModuleUsersUI/db/module.db

# Main MikoPBX database path
MIKOPBX_DB_PATH=/cf/conf/mikopbx.db

# =============================================================================
# Test Configuration
# =============================================================================

# Enable CDR test data seeding (1=enabled, 0=disabled)
# Note: The database already has 272k+ records, seeding may not be needed
ENABLE_CDR_SEED=0

# Enable CDR test data cleanup after tests (1=enabled, 0=disabled)
ENABLE_CDR_CLEANUP=1

# Enable full system cleanup after tests (1=enabled, 0=disabled)
# WARNING: This will delete all test groups and users
ENABLE_FULL_CLEANUP=1
